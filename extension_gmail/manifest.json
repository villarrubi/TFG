{
  "manifest_version": 3,
  "name": "Detector de Phishing para Gmail",
  "version": "1.0.0",
  "description": "Muestra una advertencia de riesgo de phishing dentro de Gmail Web usando el detector local del TFG.",
  "permissions": ["storage"],
  "options_page": "options.html",
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
